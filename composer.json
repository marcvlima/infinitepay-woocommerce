{
    "name": "marcvlima/infinitepay-woocommerce",
    "description": "InfinitePay payment gateway for WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Marcus Lima",
            "homepage": "https://github.com/marcvlima"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "*",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "yoast/phpunit-polyfills": "^2.0",
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "InfinitePay\\WooCommerce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InfinitePay\\WooCommerce\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=.phpcs.xml.dist",
        "phpcbf": "phpcbf --standard=.phpcs.xml.dist",
        "phpunit": "phpunit --configuration tests/phpunit.xml"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
